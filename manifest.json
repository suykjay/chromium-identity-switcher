{
  "manifest_version": 3,
  "name": "Identity Switcher",
  "version": "0.1.0",
  "description": "Per-site multi-account cookie identity switcher.",
  "permissions": ["cookies", "storage", "tabs", "activeTab"],
  "optional_host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Identity Switcher",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
